# ============================================
# RRSS - Configuración de Variables de Entorno
# ============================================
# Copia este archivo a .env y completa los valores

# --- OpenAI API ---
OPENAI_API_KEY=sk-tu-clave-aqui

# --- Meta Graph API (Instagram y Facebook) ---
META_ACCESS_TOKEN=tu-token-de-acceso
META_APP_ID=tu-app-id
META_APP_SECRET=tu-app-secret

# --- TikTok API for Business ---
TIKTOK_ACCESS_TOKEN=tu-token-de-acceso
TIKTOK_CLIENT_KEY=tu-client-key
TIKTOK_CLIENT_SECRET=tu-client-secret

# --- Configuración General ---
# Nivel de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Ruta a la base de datos SQLite
DB_PATH=data/rrss.db
